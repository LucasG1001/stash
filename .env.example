# Credenciais do banco dedicado deste projeto (PostgreSQL).
POSTGRES_USER=media
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=media_tracker

# Domínio servido pelo proxy reverso central (stack ./proxy) via HTTPS.
# Acesse pela rede WireGuard em: https://media.gomeslab.tech
# O A record de MEDIA_DOMAIN (criado no painel da Hostinger) aponta para o IP da VPN.
# Usado nas labels do serviço web para o caddy-docker-proxy rotear o domínio.
MEDIA_DOMAIN=media.gomeslab.tech

# APIs externas usadas pelo backend (filmes/séries/livros/jogos).
TMDB_API_KEY=
GOOGLE_BOOKS_API_KEY=
# IGDB / Twitch — crie um app em https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
# YouTube Data API v3 — crie uma chave em https://console.cloud.google.com (ative "YouTube Data API v3").
YOUTUBE_API_KEY=

# API key do projeto media-tracker cadastrado na notify-api.
# Gerada na notify-api via POST /api/projects (ver passos de deploy).
NOTIFY_API_KEY=
